APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=omni_csx
POSTGRES_USER=omni
POSTGRES_PASSWORD=omni

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg://omni:omni@127.0.0.1:5432/omni_csx
REDIS_URL=redis://127.0.0.1:6379/0

API_GATEWAY_PORT=8000
DOMAIN_SERVICE_PORT=8001
AI_ORCHESTRATOR_PORT=8002
KNOWLEDGE_SERVICE_PORT=8003
MOCK_PLATFORM_SERVER_PORT=8004

ODOO_BASE_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_API_KEY=your-api-key-here
ODOO_TIMEOUT=30
ODOO_VERIFY_SSL=true
ODOO_PROVIDER_MODE=mock
ODOO_SCHEDULED_REFRESH_ENABLED=false
ODOO_REFRESH_INTERVAL_INVENTORY=900
ODOO_REFRESH_INTERVAL_AUDIT=1800
